{
  "name": "revine",
  "version": "0.9.0",
  "description": "A react framework, but better.",
  "license": "ISC",
  "author": "Rachit Bharadwaj",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "revine": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./routing": {
      "import": "./dist/runtime/routing/fileBased.js",
      "types": "./dist/runtime/routing/fileBased.d.ts"
    },
    "./bundler/*": {
      "import": "./dist/runtime/bundler/*.js",
      "types": "./dist/runtime/bundler/*.d.ts"
    }
  },

  "typesVersions": {
    "*": {
      "routing": [
        "./dist/runtime/routing/fileBased.d.ts"
      ],
      "bundler/*": [
        "./dist/runtime/bundler/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cross-spawn": "^7.0.6",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.4.1",
    "lodash-es": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "vite": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.9",
    "@types/node": "^22.13.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.7.3"
  }
}
